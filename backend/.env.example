# FairwayIQ Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (for AI analysis features)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DataGolf API Key (optional - for live SG data)
# Get yours at: https://datagolf.com/api-access
DATAGOLF_API_KEY=your_datagolf_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
